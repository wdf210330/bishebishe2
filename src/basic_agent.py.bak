"""
basic_agent.py - 基础自动驾驶Agent

功能说明：
    CARLA官方提供的基础自动驾驶Agent实现
    能够沿着随机路径点行驶，响应交通信号灯，避让其他车辆
    是Xagent的基类，提供了通用的导航、感知和规划框架

主要功能：
    - 全局路径规划（基于GlobalRoutePlanner）
    - 局部路径跟踪（基于LocalPlanner）
    - 交通信号灯检测与响应
    - 前方车辆检测与紧急制动
    - 随机路径点漫游模式

参考文献：
    - CARLA官方Agent实现
    - 版权：Copyright (c) 2018-2020 CVC
    - 协议：MIT License

作者：CARLA Team
"""

# Copyright (c) 2018-2020 CVC.
# This work is licensed under the terms of the MIT license.
# For a copy, see <https://opensource.org/licenses/MIT>.

import carla
from enum import Enum
from shapely.geometry import Polygon

from local_planner import LocalPlanner
from global_route_planner import GlobalRoutePlanner
from misc import get_speed, is_within_distance, get_trafficlight_trigger_location, compute_distance


class BasicAgent(object):
    """
    基础自动驾驶Agent类
    
    实现了在CARLA仿真环境中导航的基本功能：
    - 沿着指定路径或随机路径点行驶
    - 检测并响应交通信号灯（红灯停）
    - 检测前方车辆并执行紧急制动
    - 支持配置不同的驾驶模式参数
    
    注意：
    - 忽略停车标志（stop signs）
    - 不会主动超车或换道
    - 使用LocalPlanner进行局部路径跟踪
    
    使用示例：
        agent = BasicAgent(vehicle, target_speed=20)
        agent.set_destination(end_location)
        while not agent.done():
            control = agent.run_step()
            vehicle.apply_control(control)
    """
    
    def __init__(self, vehicle, target_speed=10, opt_dict=None):
        """
        初始化BasicAgent
        
        参数：
            vehicle: CARLA车辆Actor，Agent要控制的车辆
            target_speed: 目标速度（km/h），默认10
            opt_dict: 可选参数字典，用于覆盖默认参数
        
        可配置参数（通过opt_dict传入）：
            - target_speed: 目标速度
            - ignore_traffic_lights: 是否忽略交通灯
            - ignore_stop_signs: 是否忽略停车标志
            - ignore_vehicles: 是否忽略其他车辆
            - sampling_resolution: 路径采样分辨率
            - base_tlight_threshold: 交通灯检测距离阈值
            - base_vehicle_threshold: 车辆检测距离阈值
            - max_brake: 最大制动强度
        """
        if opt_dict is None:
            opt_dict = {}
            
        self._vehicle = vehicle
        self._world = self._vehicle.get_world()
        self._map = self._world.get_map()
        self._last_traffic_light = None  # 上一个影响的交通灯
        
        # -------------------------------------------
        # 基础参数（可配置）
        # -------------------------------------------
        self._ignore_traffic_lights = False   # 是否忽略交通灯
        self._ignore_stop_signs = False       # 是否忽略停车标志
        self._ignore_vehicles = False         # 是否忽略其他车辆
        self._target_speed = target_speed      # 目标速度（km/h）
        self._sampling_resolution = 2.0       # 路径采样分辨率（米）
        self._base_tlight_threshold = 5.0    # 交通灯检测距离阈值（米）
        self._base_vehicle_threshold = 5.0   # 车辆检测距离阈值（米）
        self._max_brake = 0.5                  # 最大制动强度 [0, 1]
        
        # -------------------------------------------
        # 从opt_dict覆盖参数
        # -------------------------------------------
        opt_dict['target_speed'] = target_speed
        if 'ignore_traffic_lights' in opt_dict:
            self._ignore_traffic_lights = opt_dict['ignore_traffic_lights']
        if 'ignore_stop_signs' in opt_dict:
            self._ignore_stop_signs = opt_dict['ignore_stop_signs']
        if 'ignore_vehicles' in opt_dict:
            self._ignore_vehicles = opt_dict['ignore_vehicles']
        if 'sampling_resolution' in opt_dict:
            self._sampling_resolution = opt_dict['sampling_resolution']
        if 'base_tlight_threshold' in opt_dict:
            self._base_tlight_threshold = opt_dict['base_tlight_threshold']
        if 'base_vehicle_threshold' in opt_dict:
            self._base_vehicle_threshold = opt_dict['base_vehicle_threshold']
        if 'max_brake' in opt_dict:
            self._max_brake = opt_dict['max_brake']
        
        # -------------------------------------------
        # 初始化规划器
        # -------------------------------------------
        # LocalPlanner：局部路径跟踪，负责产生控制指令
        self._local_planner = LocalPlanner(self._vehicle, opt_dict=opt_dict)
        # GlobalRoutePlanner：全局路径规划，负责计算最短路径
        self._global_planner = GlobalRoutePlanner(self._map, self._sampling_resolution)
    
    def add_emergency_stop(self, control):
        """
        将控制指令覆盖为紧急制动
        
        用于检测到障碍物时立即停车
        保持方向盘不变以避免在转弯时偏离车道
        
        参数：
            control: 原始carla.VehicleControl对象
        
        返回：
            修改后的control，throttle=0, brake=max_brake
        """
        control.throttle = 0.0        # 停止加速
        control.brake = self._max_brake  # 最大制动
        control.hand_brake = False    # 不拉手刹
        return control
    
    def set_target_speed(self, speed):
        """
        更改Agent的目标速度
        
        参数：
            speed: 目标速度（km/h）
        """
        self._local_planner.set_speed(speed)
    
    def follow_speed_limits(self, value=True):
        """
        启用/禁用速度限制跟随
        
        启用后，Agent会根据当前道路的速度限制动态调整目标速度
        
        参数：
            value: True=启用，False=禁用
        """
        self._local_planner.follow_speed_limits(value)
    
    def get_local_planner(self):
        """获取LocalPlanner实例"""
        return self._local_planner
    
    def get_global_planner(self):
        """获取GlobalRoutePlanner实例"""
        return self._global_planner
    
    def set_destination(self, end_location, start_location=None):
        """
        设置目的地，启动路径跟踪
        
        使用全局路径规划器计算从起点到终点的路径，
        并将路径交给局部规划器跟踪
        
        参数：
            end_location: 终点CARLA.Location
            start_location: 起点CARLA.Location，如果为None则使用车辆当前位置
        """
        # 确定起点位置
        if not start_location:
            # 使用局部规划器的目标点（默认是车辆前方5米）
            start_location = self._local_planner.target_waypoint.transform.location
            clean_queue = True
        else:
            start_location = self._vehicle.get_location()
            clean_queue = True
        
        # 获取起点和终点的Waypoint
        start_waypoint = self._map.get_waypoint(start_location)
        end_waypoint = self._map.get_waypoint(end_location)
        
        # 全局路径规划
        route_trace = self.trace_route(start_waypoint, end_waypoint)
        
        # 设置给局部规划器
        self._local_planner.set_global_plan(route_trace, clean_queue=clean_queue)
    
    def set_global_plan(self, plan, stop_waypoint_creation=True, clean_queue=True):
        """
        直接设置全局规划路径
        
        用于已经计算好路径的情况（如Xagent中使用）
        
        参数：
            plan: 路径列表 [(carla.Waypoint, RoadOption), ...]
            stop_waypoint_creation: 是否停止自动生成随机路径点
            clean_queue: 是否清空当前路径队列
        """
        self._local_planner.set_global_plan(
            plan,
            stop_waypoint_creation=stop_waypoint_creation,
            clean_queue=clean_queue
        )
    
    def trace_route(self, start_waypoint, end_waypoint):
        """
        计算两点之间的最短路径
        
        参数：
            start_waypoint: 起点carla.Waypoint
            end_waypoint: 终点carla.Waypoint
        
        返回：
            route_trace: 路径列表 [(carla.Waypoint, RoadOption), ...]
        """
        start_location = start_waypoint.transform.location
        end_location = end_waypoint.transform.location
        return self._global_planner.trace_route(start_location, end_location)
    
    def run_step(self):
        """
        执行一步导航（核心方法）
        
        每帧调用一次，完成：
        1. 感知：检测前方车辆和交通灯
        2. 决策：判断是否有危险
        3. 规划：由LocalPlanner产生控制指令
        4. 如有危险，执行紧急制动
        
        返回：
            control: carla.VehicleControl对象，包含油门、刹车、方向盘
        """
        hazard_detected = False  # 是否检测到危险
        
        # -------------------------------------------
        # 1. 感知：获取周围Actor列表
        # -------------------------------------------
        actor_list = self._world.get_actors()
        vehicle_list = actor_list.filter("*vehicle*")   # 所有车辆
        lights_list = actor_list.filter("*traffic_light*")  # 所有交通灯
        
        # 计算当前速度（m/s）
        vehicle_speed = get_speed(self._vehicle) / 3.6
        
        # -------------------------------------------
        # 2. 检测前方车辆障碍
        # -------------------------------------------
        # 检测距离随速度增加（更早发现，早反应）
        max_vehicle_distance = self._base_vehicle_threshold + vehicle_speed
        affected_by_vehicle, _, _ = self._vehicle_obstacle_detected(
            vehicle_list, max_vehicle_distance
        )
        if affected_by_vehicle:
            hazard_detected = True
        
        # -------------------------------------------
        # 3. 检测交通信号灯
        # -------------------------------------------
        max_tlight_distance = self._base_tlight_threshold + vehicle_speed
        affected_by_tlight, _ = self._affected_by_traffic_light(
            lights_list, max_tlight_distance
        )
        # 红灯时不清除hazard标志（保留车辆检测结果）
        if affected_by_tlight:
            hazard_detected = False
        
        # -------------------------------------------
        # 4. 局部路径规划：生成控制指令
        # -------------------------------------------
        control = self._local_planner.run_step()
        
        # -------------------------------------------
        # 5. 紧急制动（如有危险）
        # -------------------------------------------
        if hazard_detected:
            control = self.add_emergency_stop(control)
        
        return control
    
    def done(self):
        """
        检查Agent是否到达目的地
        
        返回：
            True=已到达，False=仍在行驶
        """
        return self._local_planner.done()
    
    def ignore_traffic_lights(self, active=True):
        """启用/禁用交通灯检测"""
        self._ignore_traffic_lights = active
    
    def ignore_stop_signs(self, active=True):
        """启用/禁用停车标志检测（当前版本未实现）"""
        self._ignore_stop_signs = active
    
    def ignore_vehicles(self, active=True):
        """启用/禁用车辆检测"""
        self._ignore_vehicles = active
    
    def _affected_by_traffic_light(self, lights_list=None, max_distance=None):
        """
        检测当前是否受红灯影响
        
        判断逻辑：
        1. 过滤掉不在同一道路上的交通灯
        2. 检查是否在交通灯前方（同向）
        3. 检查是否为红灯状态
        4. 检查是否在检测距离内
        
        参数：
            lights_list: 交通灯列表，None则获取所有
            max_distance: 最大检测距离，None则使用默认值
        
        返回：
            (affected, traffic_light): (是否受影响, 影响的交通灯)
        """
        # 忽略模式直接返回
        if self._ignore_traffic_lights:
            return (False, None)
        
        # 获取交通灯列表
        if not lights_list:
            lights_list = self._world.get_actors().filter("*traffic_light*")
        
        if not max_distance:
            max_distance = self._base_tlight_threshold
        
        # 检查上一个交通灯状态
        if self._last_traffic_light:
            if self._last_traffic_light.state != carla.TrafficLightState.Red:
                self._last_traffic_light = None
            else:
                return (True, self._last_traffic_light)
        
        # 获取车辆当前位置和所在Waypoint
        ego_vehicle_location = self._vehicle.get_location()
        ego_vehicle_waypoint = self._map.get_waypoint(ego_vehicle_location)
        
        # 遍历所有交通灯
        for traffic_light in lights_list:
            # 获取交通灯触发区域的位置
            object_location = get_trafficlight_trigger_location(traffic_light)
            object_waypoint = self._map.get_waypoint(object_location)
            
            # 检查是否在同一道路上
            if object_waypoint.road_id != ego_vehicle_waypoint.road_id:
                continue
            
            # 检查是否在车辆前方（点积判断方向）
            ve_dir = ego_vehicle_waypoint.transform.get_forward_vector()
            wp_dir = object_waypoint.transform.get_forward_vector()
            dot_ve_wp = ve_dir.x * wp_dir.x + ve_dir.y * wp_dir.y + ve_dir.z * wp_dir.z
            
            if dot_ve_wp < 0:
                # 交通灯在车辆后方，跳过
                continue
            
            # 检查是否为红灯
            if traffic_light.state != carla.TrafficLightState.Red:
                continue
            
            # 检查距离
            if is_within_distance(
                object_waypoint.transform, 
                self._vehicle.get_transform(), 
                max_distance, 
                [0, 90]  # 角度范围：正前方90度
            ):
                self._last_traffic_light = traffic_light
                return (True, traffic_light)
        
        return (False, None)
    
    def _vehicle_obstacle_detected(self, vehicle_list=None, max_distance=None, 
                                   up_angle_th=90, low_angle_th=0, lane_offset=0):
        """
        检测前方是否有车辆障碍物
        
        使用多边形碰撞检测判断是否有车辆阻挡去路
        
        参数：
            vehicle_list: 车辆列表，None则获取所有
            max_distance: 最大检测距离
            up_angle_th: 检测角度上限（度）
            low_angle_th: 检测角度下限（度）
            lane_offset: 车道偏移量（用于换道检测）
        
        返回：
            (blocked, vehicle, distance): (是否阻挡, 障碍车辆, 距离)
        """
        # 忽略模式直接返回
        if self._ignore_vehicles:
            return (False, None, -1)
        
        # 获取车辆列表
        if not vehicle_list:
            vehicle_list = self._world.get_actors().filter("*vehicle*")
        
        if not max_distance:
            max_distance = self._base_vehicle_threshold
        
        # 获取车辆自身信息
        ego_transform = self._vehicle.get_transform()
        ego_wpt = self._map.get_waypoint(self._vehicle.get_location())
        
        # 根据车道方向调整偏移量
        if ego_wpt.lane_id < 0 and lane_offset != 0:
            lane_offset *= -1
        
        # 计算车辆前端位置（用于前方检测）
        ego_forward_vector = ego_transform.get_forward_vector()
        ego_extent = self._vehicle.bounding_box.extent.x  # 车辆半长
        ego_front_transform = ego_transform
        ego_front_transform.location += carla.Location(
            x=ego_extent * ego_forward_vector.x,
            y=ego_extent * ego_forward_vector.y,
        )
        
        # -------------------------------------------
        # 遍历所有车辆检测
        # -------------------------------------------
        for target_vehicle in vehicle_list:
            target_transform = target_vehicle.get_transform()
            target_wpt = self._map.get_waypoint(
                target_transform.location, 
                lane_type=carla.LaneType.Any
            )
            
            # -------------------------------------------
            # 简单模式：不在交叉口时
            # -------------------------------------------
            if not ego_wpt.is_junction or not target_wpt.is_junction:
                # 检查是否在同一车道
                if (target_wpt.road_id != ego_wpt.road_id or 
                    target_wpt.lane_id != ego_wpt.lane_id + lane_offset):
                    # 不在当前车道，检查下一个车道
                    next_wpt = self._local_planner.get_incoming_waypoint_and_direction(steps=3)[0]
                    if not next_wpt:
                        continue
                    if (target_wpt.road_id != next_wpt.road_id or 
                        target_wpt.lane_id != next_wpt.lane_id + lane_offset):
                        continue
                
                # 计算目标车辆后端位置
                target_forward_vector = target_transform.get_forward_vector()
                target_extent = target_vehicle.bounding_box.extent.x
                target_rear_transform = target_transform
                target_rear_transform.location -= carla.Location(
                    x=target_extent * target_forward_vector.x,
                    y=target_extent * target_forward_vector.y,
                )
                
                # 检测距离和角度
                if is_within_distance(
                    target_rear_transform, 
                    ego_front_transform, 
                    max_distance, 
                    [low_angle_th, up_angle_th]
                ):
                    return (
                        True, 
                        target_vehicle, 
                        compute_distance(target_transform.location, ego_transform.location)
                    )
            
            # -------------------------------------------
            # 交叉口模式：使用多边形碰撞检测
            # -------------------------------------------
            else:
                # 构建车辆行驶路径的多边形
                route_bb = []
                ego_location = ego_transform.location
                extent_y = self._vehicle.bounding_box.extent.y  # 车辆半宽
                r_vec = ego_transform.get_right_vector()
                
                # 车辆前端两个角点
                p1 = ego_location + carla.Location(extent_y * r_vec.x, extent_y * r_vec.y)
                p2 = ego_location + carla.Location(-extent_y * r_vec.x, -extent_y * r_vec.y)
                route_bb.append([p1.x, p1.y, p1.z])
                route_bb.append([p2.x, p2.y, p2.z])
                
                # 路径上的点
                for wp, _ in self._local_planner.get_plan():
                    if ego_location.distance(wp.transform.location) > max_distance:
                        break
                    
                    r_vec = wp.transform.get_right_vector()
                    p1 = wp.transform.location + carla.Location(extent_y * r_vec.x, extent_y * r_vec.y)
                    p2 = wp.transform.location + carla.Location(-extent_y * r_vec.x, -extent_y * r_vec.y)
                    route_bb.append([p1.x, p1.y, p1.z])
                    route_bb.append([p2.x, p2.y, p2.z])
                
                if len(route_bb) < 3:
                    # 点太少无法形成多边形
                    return (False, None, -1)
                
                # 构建路径多边形
                ego_polygon = Polygon(route_bb)
                
                # 检查每辆目标车辆
                for target_vehicle in vehicle_list:
                    if target_vehicle.id == self._vehicle.id:
                        continue  # 跳过自己
                    
                    target_extent = target_vehicle.bounding_box.extent.x
                    if ego_location.distance(target_vehicle.get_location()) > max_distance:
                        continue
                    
                    # 构建目标车辆的多边形
                    target_bb = target_vehicle.bounding_box
                    target_vertices = target_bb.get_world_vertices(target_vehicle.get_transform())
                    target_list = [[v.x, v.y, v.z] for v in target_vertices]
                    target_polygon = Polygon(target_list)
                    
                    # 多边形碰撞检测
                    if ego_polygon.intersects(target_polygon):
                        return (
                            True, 
                            target_vehicle, 
                            compute_distance(target_vehicle.get_location(), ego_location)
                        )
                
                return (False, None, -1)
        
        return (False, None, -1)
